{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@zenobius/opencode-background"
  ],
  "agent": {
    "git": {
      "description": "git agent for codebase management",
      "mode": "subagent",
      "model": "ollama/qwen3:4b",
      "prompt": "{file:./prompt/git-agent.md}"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b"
        },
        "qwen3:4b": {
          "name": "qwen3:4b"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  },
  "command": {
    "git-commit": {
      "description": "Review staged changes, create commit message, and commit to the git repository",
      "agent": "git",
      "template": "{file:./template/git-commit.md}",
      "model": "ollama/qwen3:4b",
      "subtask": true
    }
  },
  "permission": {
    "bash": {
      "git commit*": "ask",
      "git add*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git checkout*": "ask",
      "git status": "allow",
      "git log": "allow",
      "git diff": "allow",
      "git branch": "allow"
    }
  }
}